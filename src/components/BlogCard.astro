---
interface Props {
  title: string;
  description: string;
  slug: string;
  niche: string;
  pubDate: Date;
  author?: string;
}

const { title, description, slug, niche, pubDate, author = 'Lucentra Team' } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric'
});
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-meta">
    <span class="tag">{niche.replace(/-/g, ' ')}</span>
    <span class="blog-card-date">{formattedDate}</span>
  </div>
  <h3 class="blog-card-title">{title}</h3>
  <p class="blog-card-desc">{description}</p>
  <div class="blog-card-footer">
    <span class="blog-card-author">{author}</span>
    <span class="blog-card-cta">Read more →</span>
  </div>
</a>

<style>
.blog-card {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 28px;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  transition: all 0.25s ease;
  cursor: pointer;
}

.blog-card:hover {
  border-color: var(--teal);
  box-shadow: var(--shadow);
  transform: translateY(-2px);
}

.blog-card-meta {
  display: flex;
  align-items: center;
  gap: 12px;
}

.blog-card-date {
  font-size: 13px;
  color: var(--text-light);
}

.blog-card-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--near-black);
  line-height: 1.3;
}

.blog-card:hover .blog-card-title { color: var(--teal-dark); }

.blog-card-desc {
  font-size: 14px;
  color: var(--text-muted);
  line-height: 1.6;
  flex: 1;
  margin: 0;
}

.blog-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

.blog-card-author {
  font-size: 13px;
  color: var(--text-muted);
  font-weight: 500;
}

.blog-card-cta {
  font-size: 13px;
  font-weight: 600;
  color: var(--teal);
}
</style>
