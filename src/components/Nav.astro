---
const industries = [
  { label: 'Finance', href: '/industries/finance' },
  { label: 'Education', href: '/industries/education' },
  { label: 'SaaS', href: '/industries/saas' },
  { label: 'E-commerce', href: '/industries/ecommerce' },
  { label: 'Brick & Mortar', href: '/industries/brick-and-mortar' },
];

const commitments = [
  { label: 'Merit', href: '/commitments/merit' },
  { label: 'Opportunity', href: '/commitments/opportunity' },
  { label: 'Responsibility', href: '/commitments/responsibility' },
];
---

<header class="nav-header" id="nav">
  <div class="container nav-inner">
    <!-- Logo -->
    <a href="/" class="nav-logo">
      Lucentra<span class="logo-dot">.</span>
    </a>

    <!-- Desktop links -->
    <nav class="nav-links">
      <!-- Industries dropdown -->
      <div class="nav-item has-dropdown">
        <button class="nav-link dropdown-trigger" aria-haspopup="true">
          Industries
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dropdown">
          {industries.map(item => (
            <a href={item.href} class="dropdown-item">{item.label}</a>
          ))}
        </div>
      </div>

      <!-- Commitments dropdown -->
      <div class="nav-item has-dropdown">
        <button class="nav-link dropdown-trigger" aria-haspopup="true">
          Commitments
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="dropdown">
          {commitments.map(item => (
            <a href={item.href} class="dropdown-item">{item.label}</a>
          ))}
        </div>
      </div>

      <a href="/how-we-work" class="nav-link">How We Work</a>
      <a href="/blog" class="nav-link">Blog</a>
    </nav>

    <a href="/#contact" class="btn btn-primary nav-cta">Get Started</a>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <div class="mobile-section">
      <p class="mobile-label">Industries</p>
      {industries.map(item => (
        <a href={item.href} class="mobile-link">{item.label}</a>
      ))}
    </div>
    <div class="mobile-section">
      <p class="mobile-label">Commitments</p>
      {commitments.map(item => (
        <a href={item.href} class="mobile-link">{item.label}</a>
      ))}
    </div>
    <div class="mobile-section">
      <a href="/how-we-work" class="mobile-link">How We Work</a>
      <a href="/blog" class="mobile-link">Blog</a>
    </div>
    <a href="/#contact" class="btn btn-primary" style="width:100%; justify-content:center; margin-top:8px;">Get Started</a>
  </div>
</header>

<style>
.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: var(--nav-h);
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  z-index: 100;
  transition: box-shadow 0.2s;
}

.nav-header.scrolled {
  box-shadow: 0 2px 20px rgba(0,0,0,0.08);
}

.nav-inner {
  height: var(--nav-h);
  display: flex;
  align-items: center;
  gap: 40px;
}

.nav-logo {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 800;
  color: var(--near-black);
  letter-spacing: -0.02em;
  flex-shrink: 0;
}

.logo-dot { color: var(--teal); }

.nav-links {
  display: flex;
  align-items: center;
  gap: 4px;
  flex: 1;
}

.nav-item { position: relative; }

.nav-link {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 8px 14px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-muted);
  background: none;
  border: none;
  border-radius: var(--radius);
  cursor: pointer;
  transition: all 0.15s;
  font-family: var(--font-body);
  white-space: nowrap;
}

.nav-link:hover { color: var(--near-black); background: var(--bg-alt); }

.dropdown {
  position: absolute;
  top: 100%;
  padding-top: 8px;
  left: 0;
  background: white;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 8px;
  min-width: 200px;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px);
  transition: all 0.2s ease;
  pointer-events: none;
}

.has-dropdown:hover .dropdown {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
  pointer-events: auto;
}

.dropdown-item {
  display: block;
  padding: 9px 14px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text-muted);
  border-radius: var(--radius);
  transition: all 0.15s;
}

.dropdown-item:hover {
  color: var(--teal-dark);
  background: var(--teal-light);
}

.nav-cta { margin-left: auto; flex-shrink: 0; padding: 10px 20px; font-size: 14px; }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  padding: 8px;
  margin-left: auto;
  cursor: pointer;
}

.hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--near-black);
  border-radius: 2px;
  transition: all 0.2s;
}

/* Mobile menu */
.mobile-menu {
  display: none;
  padding: 16px 24px 24px;
  border-top: 1px solid var(--border);
  background: white;
  flex-direction: column;
  gap: 8px;
}

.mobile-menu.open { display: flex; }

.mobile-section { display: flex; flex-direction: column; gap: 2px; margin-bottom: 12px; }

.mobile-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-light);
  padding: 0 12px;
  margin-bottom: 4px;
}

.mobile-link {
  padding: 10px 12px;
  font-size: 15px;
  font-weight: 500;
  color: var(--text);
  border-radius: var(--radius);
  transition: all 0.15s;
}

.mobile-link:hover { color: var(--teal); background: var(--teal-light); }

@media (max-width: 900px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
  .nav-header { height: auto; min-height: var(--nav-h); }
}
</style>

<script>
  const nav = document.getElementById('nav');
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 20);
  });

  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });
</script>
