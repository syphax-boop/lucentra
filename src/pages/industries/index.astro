---
import BaseLayout from '../../layouts/BaseLayout.astro';

const industries = [
  {
    href: '/industries/finance',
    title: 'Finance',
    desc: 'Banks, fintech, advisory firms, and investment companies modernizing to serve the next generation of clients.',
    points: ['Automated onboarding', 'AI-powered client insights', 'Digital marketing for advisors'],
  },
  {
    href: '/industries/education',
    title: 'Education',
    desc: 'Schools, universities, training companies, and online platforms building the digital experiences learners expect.',
    points: ['Student journey optimization', 'Enrollment systems', 'Retention automation'],
  },
  {
    href: '/industries/saas',
    title: 'SaaS',
    desc: 'Software companies at every stage building the acquisition, activation, and retention systems that drive durable growth.',
    points: ['Growth system audits', 'Activation optimization', 'Churn reduction strategy'],
  },
  {
    href: '/industries/ecommerce',
    title: 'E-commerce',
    desc: 'Online stores and DTC brands fixing conversion leaks and building the marketing engines that turn visitors into loyal customers.',
    points: ['Conversion rate optimization', 'Email & SMS automation', 'Paid acquisition strategy'],
  },
  {
    href: '/industries/brick-and-mortar',
    title: 'Brick & Mortar',
    desc: 'Physical businesses — retail, hospitality, services — building the digital presence and systems that bring customers through the door.',
    points: ['Local SEO & visibility', 'Review generation', 'Customer reactivation'],
  },
];
---
<BaseLayout title="Industries — Lucentra" description="Lucentra works across five core industries: Finance, Education, SaaS, E-commerce, and Brick & Mortar businesses.">

  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Industries</span>
      <h1>We go deep, not wide.</h1>
      <p>Lucentra focuses on five industries where we can deliver the most impact. Deep expertise beats broad generalism — every time.</p>
    </div>
  </section>

  <section class="industries-list">
    <div class="container">
      {industries.map((ind, i) => (
        <a href={ind.href} class="industry-row">
          <div class="industry-row-number">0{i + 1}</div>
          <div class="industry-row-content">
            <h2>{ind.title}</h2>
            <p>{ind.desc}</p>
            <div class="industry-points">
              {ind.points.map(pt => <span class="point-tag">{pt}</span>)}
            </div>
          </div>
          <div class="industry-row-arrow">→</div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  padding: 72px 0 64px;
  background: var(--bg-alt);
  border-bottom: 1px solid var(--border);
}
.page-hero h1 { font-size: clamp(36px, 5vw, 60px); font-weight: 800; margin-bottom: 16px; margin-top: 8px; }
.page-hero p { font-size: 18px; color: var(--text-muted); max-width: 500px; margin: 0; }

.industries-list { padding: 64px 0 96px; }

.industry-row {
  display: grid;
  grid-template-columns: 64px 1fr 48px;
  gap: 32px;
  align-items: center;
  padding: 36px 0;
  border-bottom: 1px solid var(--border);
  transition: all 0.2s;
}
.industry-row:first-child { padding-top: 0; }
.industry-row:hover { background: none; }
.industry-row:hover h2 { color: var(--teal-dark); }
.industry-row:hover .industry-row-arrow { color: var(--teal); transform: translateX(4px); }

.industry-row-number {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 800;
  color: var(--text-light);
}

.industry-row-content h2 { font-size: 28px; font-weight: 800; margin-bottom: 8px; transition: color 0.2s; }
.industry-row-content p { color: var(--text-muted); font-size: 16px; margin-bottom: 16px; max-width: 600px; }

.industry-points { display: flex; gap: 8px; flex-wrap: wrap; }
.point-tag {
  padding: 4px 12px;
  background: var(--bg-alt);
  border: 1px solid var(--border);
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-muted);
}

.industry-row-arrow {
  font-size: 20px;
  color: var(--text-light);
  transition: all 0.2s;
  text-align: right;
}

@media (max-width: 640px) {
  .industry-row { grid-template-columns: 40px 1fr 32px; gap: 16px; }
}
</style>
