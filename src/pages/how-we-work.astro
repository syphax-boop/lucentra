---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const steps = [
  {
    number: '01',
    title: 'Diagnose',
    headline: 'We start by understanding — not assuming.',
    body: 'Before we propose anything, we spend time understanding your business: the systems you use, the goals you have, the obstacles in the way, and the opportunities you might be missing. We\'re looking for the real problem, not the surface-level symptoms.',
    items: ['Business and systems audit', 'Competitive landscape review', 'Stakeholder conversations', 'Current marketing and tech stack analysis'],
  },
  {
    number: '02',
    title: 'Design',
    headline: 'We build a roadmap that\'s clear, sequenced, and realistic.',
    body: 'Good strategy isn\'t just knowing what to do — it\'s knowing what to do first. We prioritize the highest-leverage changes and build a phased roadmap that shows you exactly what we\'re doing, when, and why. No guesswork, no vague promises.',
    items: ['Strategic roadmap and prioritization', 'Technology and tooling recommendations', 'Marketing strategy and positioning', 'KPIs and success metrics'],
  },
  {
    number: '03',
    title: 'Deliver',
    headline: 'We build and launch — with you, not just for you.',
    body: 'We don\'t hand over a document and disappear. We stay in the work through execution — building systems, launching campaigns, integrating technology, and training your team where needed. The goal is for your business to be measurably better, not just to have a new strategy deck.',
    items: ['System implementation and integration', 'Campaign creation and launch', 'Content development', 'Team enablement and training'],
  },
  {
    number: '04',
    title: 'Optimize',
    headline: 'We measure, learn, and compound.',
    body: 'After delivery, we don\'t stop. We track the metrics that matter, identify what\'s working and what isn\'t, and make the adjustments that turn a good start into lasting results. Real growth compounds — and that requires iteration, not just installation.',
    items: ['Performance tracking and reporting', 'A/B testing and experimentation', 'Ongoing strategy refinement', 'Quarterly business reviews'],
  },
];
---
<BaseLayout title="How We Work — Lucentra" description="Lucentra's four-phase approach: Diagnose, Design, Deliver, Optimize. We don't just deliver — we transform.">

  <section class="how-hero">
    <div class="container">
      <span class="eyebrow">How We Work</span>
      <h1>We don't just deliver.<br/>We transform.</h1>
      <p>Most agencies hand you a deliverable and disappear. We step into your business, find what's broken, build what's missing, and stay until results are real and compounding.</p>
    </div>
    <div class="how-hero-bg" aria-hidden="true"></div>
  </section>

  <section class="how-steps-section">
    <div class="container">
      {steps.map((step, i) => (
        <div class="step-block">
          <div class="step-block-header">
            <span class="step-big-number">{step.number}</span>
            <div>
              <span class="eyebrow">{step.title}</span>
              <h2>{step.headline}</h2>
            </div>
          </div>
          <div class="step-block-body">
            <p class="step-body-text">{step.body}</p>
            <div class="step-items">
              {step.items.map(item => (
                <div class="step-item">
                  <span class="step-item-dot"></span>
                  {item}
                </div>
              ))}
            </div>
          </div>
          {i < steps.length - 1 && <div class="step-connector" aria-hidden="true">↓</div>}
        </div>
      ))}
    </div>
  </section>

  <!-- Solutions CTA -->
  <section class="solutions-section">
    <div class="container">
      <div class="solutions-inner">
        <div>
          <span class="eyebrow" style="color: var(--teal-mid);">Our Solutions</span>
          <h2 style="color: white;">The three pillars we draw from.</h2>
          <p style="color: rgba(255,255,255,0.6);">Every engagement combines strategic consulting, AI implementation, and creative marketing — in whatever proportion your business needs most.</p>
        </div>
        <div class="solutions-cards">
          {[
            { title: 'Strategic Digital Consulting', desc: 'Systems, strategy, and roadmapping for businesses ready to modernize.' },
            { title: 'Making AI Work for Business', desc: 'Practical AI implementation that saves time and generates revenue.' },
            { title: 'Creative Marketing & Lead Generation', desc: 'Campaigns and systems that attract the right clients.' },
          ].map(s => (
            <div class="solutions-card">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ContactForm />

</BaseLayout>

<style>
.how-hero {
  position: relative;
  padding: 80px 0 72px;
  overflow: hidden;
  background: var(--bg-alt);
  border-bottom: 1px solid var(--border);
}
.how-hero h1 {
  font-size: clamp(40px, 6vw, 72px);
  font-weight: 800;
  margin-bottom: 20px;
  margin-top: 8px;
  line-height: 1.1;
}
.how-hero p { font-size: 18px; color: var(--text-muted); max-width: 560px; margin: 0; }
.how-hero-bg {
  position: absolute; top: -80px; right: -120px;
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(10,171,171,0.07) 0%, transparent 70%);
  border-radius: 50%; pointer-events: none; z-index: 0;
}

.how-steps-section { padding: 80px 0; }

.step-block {
  max-width: 800px;
  margin: 0 auto;
}

.step-block-header {
  display: flex;
  align-items: flex-start;
  gap: 32px;
  margin-bottom: 28px;
}

.step-big-number {
  font-family: var(--font-display);
  font-size: 80px;
  font-weight: 800;
  color: var(--teal-light);
  line-height: 1;
  flex-shrink: 0;
  margin-top: -8px;
}

.step-block-header h2 {
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 800;
  margin-top: 8px;
}

.step-block-body {
  padding-left: 112px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  margin-bottom: 0;
}

.step-body-text { font-size: 16px; color: var(--text-muted); line-height: 1.7; margin: 0; }

.step-items { display: flex; flex-direction: column; gap: 10px; }
.step-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
}
.step-item-dot {
  width: 6px; height: 6px;
  background: var(--teal);
  border-radius: 50%;
  flex-shrink: 0;
}

.step-connector {
  text-align: center;
  font-size: 24px;
  color: var(--teal);
  padding: 32px 0;
  display: block;
}

.solutions-section {
  background: var(--bg-dark);
  padding: var(--section-py) 0;
}

.solutions-inner h2 { font-size: clamp(28px, 4vw, 44px); font-weight: 800; margin-bottom: 12px; margin-top: 8px; }
.solutions-inner > div > p { font-size: 17px; margin-bottom: 48px; }

.solutions-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.solutions-card {
  padding: 28px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: var(--radius-lg);
  transition: all 0.25s;
}
.solutions-card:hover { background: rgba(10,171,171,0.1); border-color: var(--teal); }
.solutions-card h3 { font-size: 17px; font-weight: 700; color: white; margin-bottom: 8px; }
.solutions-card p { font-size: 14px; color: rgba(255,255,255,0.55); margin: 0; line-height: 1.6; }

@media (max-width: 900px) {
  .step-block-body { padding-left: 0; grid-template-columns: 1fr; gap: 24px; }
  .step-block-header { gap: 20px; }
  .step-big-number { font-size: 56px; }
  .solutions-cards { grid-template-columns: 1fr; }
}
</style>
